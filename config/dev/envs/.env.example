# Shared development environment (migrated from the old .env.docker).
# Dev services connect to Postgres/Redis on the host via host.docker.internal
# (start them with docker-compose-db.yml or your own local instances).

# Database
POSTGRES_HOST=host.docker.internal
POSTGRES_CREDENTIALS=postgres:postgres # <username>:<password>
POSTGRES_PORT=5432

# Redis (stream)
REDIS_STREAM_URL=redis://host.docker.internal:6379/0

EAGER_LOAD=1
