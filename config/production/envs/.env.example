# Production env template. Copy to the same filenames (without .example) and fill in.
# The prod overlay loads: .env.postgres + .env.common + .env.<service> per service.

# ===== .env.postgres =====
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
PGHOST=

# ===== .env.common =====
POSTGRES_HOST=
POSTGRES_PORT=
REDIS_STREAM_URL=
EAGER_LOAD=
# Observability (shared defaults; DSN per service in .env.<service>)
SENTRY_TRACES_SAMPLE_RATE=

# ===== .env.iam =====
SERVICE_JWT_KEY=
DATABASE_URI=
IDAH_SERVICE_ACCOUNT=
IDAH_SERVICE_PASSWORD=
# Sentry — fill with the idah-iam project DSN to enable telemetry
SENTRY_DSN=

# ===== .env.media =====
SERVICE_JWT_KEY=
DATABASE_URI=
IDAH_SERVICE_ACCOUNT=
IDAH_SERVICE_PASSWORD=
MEDIAS_FILES_BUCKET=
MEDIAS_FILES_ACCESS_KEY_ID=
MEDIAS_FILES_SECRET_ACCESS_KEY=
MEDIAS_FILES_REGION=
MEDIAS_FILES_ENDPOINT=
# Sentry — fill with the idah-media project DSN to enable telemetry
SENTRY_DSN=

