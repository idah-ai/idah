#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "pry"

COVERAGE_PATH = File.expand_path("./coverage/.last_run.json", Dir.pwd)
COVERAGE_MIN = 90

def download_artifact_message!
  puts "You can download the results under: "
  puts "Github Actions > Summary > Artifacts > code-coverage"
end

if File.exist?(COVERAGE_PATH)
  coverage = JSON.parse(File.read(COVERAGE_PATH))
  covered_percent = coverage["result"]["line"]

  if covered_percent < COVERAGE_MIN
    puts "Coverage is #{covered_percent}%, which is below the minimum of #{COVERAGE_MIN}%"
    download_artifact_message!

    exit 1
  else
    puts "Coverage is #{covered_percent}%"
    download_artifact_message!

    exit 0
  end
else
  puts "No coverage file found at #{COVERAGE_PATH}"
  exit 1
end
