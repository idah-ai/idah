{
  "name": "idah-image",
  "displayName": "IDAH Image Annotation",
  "description": "A module for annotating image.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
		"//build:dev": "Unminified build for tracing errors that only reproduce in the compiled (prod) env",
    "build:dev": "vite build --mode unminified",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lucide/svelte": "^0.544.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "flubber": "^0.4.2",
    "hls.js": "^1.6.16",
    "paneforge": "1.0.0-next.5",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/flubber": "^0.4.0",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "svelte": "^5.56.1",
    "svelte-check": "^4.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^3.2.6"
  }
}
