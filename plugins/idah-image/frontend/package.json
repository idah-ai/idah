    "@tailwindcss/vite": "^4.1.10",
    "@tsconfig/svelte": "^5.0.8",
    "bits-ui": "^2.17.2",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.9.2",
    "globals": "^16.2.0",
    "paneforge": "^1.0.2",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "svelte": "^5.34.3",
