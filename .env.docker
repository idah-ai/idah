# Database configuration
# Use host.docker.internal to connect to the host machine's PostgreSQL instance
POSTGRES_HOST=host.docker.internal
POSTGRES_CREDENTIALS=postgres:postgres # <username>:<password>
POSTGRES_PORT=5432

# Redis configuration
# Redis URL for stream, using host.docker.internal to connect to the host machine's Redis instance
REDIS_STREAM_URL=redis://host.docker.internal:6379/0

EAGER_LOAD=1
