#!/bin/sh

SERVICES="dataset iam media setting"

reset_service() {
  service=$1
  echo "Resetting $service service..."
  docker-compose run --rm $service bundle exec rake db:reset
}

if [ -z "$1" ]; then
  for service in $SERVICES; do
    reset_service $service
  done
else
  service=$1

  case $service in
    dataset|iam|media|setting)
      reset_service $service
      ;;
    *)
      echo "Error: Invalid service name '$service'"
      echo "Valid services: $SERVICES"
      echo "Usage: $0 [service_name]"
      echo "  $0           # Reset all services"
      echo "  $0 dataset   # Reset only dataset service"
      exit 1
      ;;
  esac
fi
