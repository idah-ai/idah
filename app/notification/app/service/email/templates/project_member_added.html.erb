
<div style="padding: 24px;text-align: center;">

  <h1>You have been invited to project '<%= notification.project_name %>'</h1>

  <p style="font-size: 14px;line-height: 20px;">Hi <%= account.name %>,</p>
  <p style="text-align: center;font-size: 14px;line-height: 20px;margin: 0 100px;">
    '<%= notification.inviter_email %>' has invited you to join the project '<%= notification.project_name %>'.
  </p>

  <div style="border: 1px solid rgba(81, 232, 203, 1); border-radius: 8px; padding: 10px 14px;width: 150px;margin: 20px auto;">
    <a href="<%= [ENV.fetch("IDAH_URL"), "/login"].join("") %>" style="text-decoration: none; color: rgba(81, 232, 203, 1); font-size: 14px; font-weight: 600;width: 150px;margin: 0 auto;">
      Accept Invitation
    </a>
  </div>
</div>
