
<div style="padding: 24px;text-align: center;">

<h1>Reset password</h1>

    <img src="<%= [ENV.fetch("IDAH_URL"), "/assets/images/email-illustration-password_reset.svg"].join("") %>" style="width: 120px; height: 120px;margin: 0 auto;" />


<p style="font-size: 14px;line-height: 20px;">Hi <%= account.name || account.email %>,</p>

  <p style="text-align: center;font-size: 14px;line-height: 20px;margin: 0 100px;">
  A password reset has been requested for your account.
  </p>

  <div style="background-color:#3A81F6; border-radius: 8px; padding: 10px 14px;width: 150px;margin: 20px auto;">
    <a href="<%= [ENV.fetch("IDAH_URL"), "/reset-password?token=#{notification.password_reset_token}"].join("") %>" style="text-decoration: none; color: #fff; font-size: 14px; font-weight: 600;width: 150px;margin: 0 auto;">
      Reset password
    </a>
  </div>

   <p style="text-align: center;font-size: 14px;line-height: 20px;margin: 0 100px;">
This password reset link will expire in 1 hour. If you are unable to complete the reset within this time, Please request a new link.  </p>
</div>
