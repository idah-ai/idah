{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run watch:idah-video\" \"vite dev --host\"",
    "watch:idah-video": "vite build --config vite.config.idah-video.js --watch",
    "build:idah-video": "vite build --config vite.config.idah-video.js",
    "build": "vite build",
    "build:parser": "peggy --format es src/plugins/idah-video/test_ast_parser.pegjs -o build/parser.js",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.0",
    "@eslint/js": "^9.29.0",
    "@internationalized/date": "^3.8.2",
    "@lucide/svelte": "^0.515.0",
    "@rollup/plugin-alias": "^5.1.1",
    "@sveltejs/adapter-auto": "^6.0.1",
    "@sveltejs/adapter-node": "^5.3.2",
    "@sveltejs/kit": "^2.21.5",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/vite": "^4.1.10",
    "@tanstack/table-core": "^8.21.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.8",
    "bits-ui": "^2.14.2",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.9.2",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "paneforge": "1.0.0-next.5",
    "peggy": "^5.0.6",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "svelte": "^5.34.3",
    "svelte-check": "^4.2.1",
    "svelte-sonner": "^1.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vaul-svelte": "1.0.0-next.7",
    "video.js": "^8.23.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "mode-watcher": "^1.1.0",
    "uuidv7": "^1.0.2",
    "zod": "^4.1.5"
  }
}
