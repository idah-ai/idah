---
import { SidebarProvider } from "$lib/components/ui/sidebar";
import ApplicationContent from "$lib/app/application/content/application-content.svelte";

const pathname = Astro.url.pathname;

---
<!-- Desktop sidebar -->
<aside class="hidden lg:flex w-64 shrink-0 bg-background">
  <div class="h-full overflow-y-auto">
    <SidebarProvider>
      Desktop Sidebar
    </SidebarProvider>
  </div>
</aside>

<!-- Mobile sidebar -->
<aside
  id="mobile-sidebar"
  class="
    fixed inset-y-0 left-0 z-40
    w-full pt-16
    -translate-x-full
    bg-background
    lg:hidden
  "
>
  <div class="h-full overflow-y-auto">
    <SidebarProvider>
    <ApplicationContent>
      Mobile Sidebar
    </ApplicationContent>
    </SidebarProvider>
  </div>
</aside>


<script>
  const sidebar = document.getElementById("mobile-sidebar");
  const toggle = document.querySelector("[data-sidebar-toggle]");

  toggle?.addEventListener("click", () => {
    sidebar?.classList.toggle("-translate-x-full");
  });
</script>