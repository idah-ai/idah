---
import Logo from "@components/app/brands/Logo.astro";
import Button from "@components/ui/Button/Button.astro";
import Input from "@components/ui/Input/Input.astro";
import { SearchIcon, TextAlignJustifyIcon } from "@lucide/astro";
---

<header id="header" class="sticky top-0 z-50 w-full border-b border-border bg-background px-4 py-3 shadow-sm md:px-8">
  <div class="mx-auto flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/">
        <Logo id="header-logo" />
      </a>
      <div class="h-6 w-px border-l border-border"></div>
      <Button href="#docs" variant="link" className="hidden xl:flex"> Docs </Button>
    </div>

    <Input placeholder="Search..." className="hidden flex-1 xl:block xl:max-w-2xl" />

    <div class="flex items-center gap-4 aling-right ml-auto">
      <Button href="#changelog" variant="link" className="hidden xl:flex"> Changelog </Button>

      <Button href="#support" variant="link" className="hidden xl:flex"> Support </Button>

      <Button href="#install" className="hidden xl:flex"> Install IDAH </Button>

      <Button variant="link" size="icon" className="xl:hidden">
        <SearchIcon class="size-4" />
      </Button>

      <Button variant="link" size="icon" className="xl:hidden">
        <TextAlignJustifyIcon class="size-4" />
      </Button>
    </div>
  </div>
</header>

<style>
  #header {
    font-family: Inter, Roboto, "Helvetica Neue", "Arial Nova", "Nimbus Sans", Arial, sans-serif;
  }
</style>
