---
import Logo from "@components/app/brands/Logo.astro";

import { Separator } from "$lib/components/ui/separator";
import { Button } from "$lib/components/ui/button";
import SidebarToggleButton from "$lib/app/button/sidebar-toggle-button.svelte";
import SearchBar from "$lib/app/bar/search-bar.svelte";
---
<header
  id="header"
  class="fixed top-0 left-0 z-50 h-16 w-full border-b bg-background px-4 shadow-sm"
>
  <div class="mx-auto flex h-full w-full max-w-7xl items-center">
    <!-- left -->
    <div class="flex items-center gap-4">
      <a href="/">
        <Logo id="header-logo" />
      </a>
      
      <Separator orientation="vertical" class="h-6 hidden lg:flex" />
      <Button href="#docs" variant="link" class="text-foreground hidden lg:flex"> Docs </Button>
    </div>

    <SearchBar client:load />

    <!-- right -->
    <div class="ml-auto flex items-center gap-1">
     <Button href="#changelog" variant="link" class="text-foreground hidden lg:flex"> Changelog </Button>

      <Button href="#support" variant="link" class="text-foreground hidden lg:flex"> Support </Button>

      <Button href="#install" class="hidden lg:flex dark:text-white"> Install IDAH </Button>
      
      <SidebarToggleButton client:load />
    </div>
  </div>
</header>
