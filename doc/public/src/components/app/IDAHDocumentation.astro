---
import BlockImg from "@assets/block-img.svg";
import ImgCard, { type ImgCardProps } from "@components/app/Card/ImgCard.astro";
import PageNavigation from "@components/ui/PageNavigation/PageNavigation.astro";

import CommonErrorTable from "@components/app/Table/CommonErrorTable.astro";

const datasets: ImgCardProps["value"][] = [
  {
    title: "Dataset 1",
    description: "Ac semper tristique commodo iaculis id venenatis sem tincidunt.",
    src: BlockImg.src,
  },
  {
    title: "Dataset 2",
    description: "Ac semper tristique commodo iaculis id venenatis sem tincidunt.",
    src: BlockImg.src,
  },
  {
    title: "Dataset 3",
    description: "Ac semper tristique commodo iaculis id venenatis sem tincidunt.",
    src: BlockImg.src,
  },
];
---

<div class="mx-auto flex max-w-7xl flex-col justify-start gap-6 p-8">
  <h1>IDAH Documentation</h1>
  <textDescription>Find the resources you need to build your computer vision application</textDescription>

  <div class="overflow-x-auto">
    <div class="grid auto-cols-[80%] grid-flow-col gap-4 sm:auto-cols-auto md:grid-flow-row md:grid-cols-3">
      {datasets.map((dataset) => <ImgCard value={dataset} />)}
    </div>
  </div>

  <h3>Support</h3>
