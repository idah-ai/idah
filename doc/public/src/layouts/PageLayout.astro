---
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout>
  <slot name="header">
    <Header />
  </slot>

  <main class="flex-grow">
    <slot />
  </main>

  <slot name="footer">
    <Footer />
  </slot>
</Layout>
