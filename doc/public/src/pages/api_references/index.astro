---
import PageLayout from "@layouts/PageLayout.astro";
import { compile } from "json-schema-to-typescript";
import { marked } from "marked";

export const prerender = false;

// Configure marked for safe rendering
marked.setOptions({
  breaks: true,
  gfm: true,
});

// Helper to render markdown safely
function renderMarkdown(text: string): string {
  if (!text) return "";
  return marked.parse(text) as string;
}

// Helper to highlight path parameters
function highlightPathParams(path: string): string {
  return path.replace(/\{([^}]+)\}/g, '<b>{$1}</b>');
}

const app = Astro.url.searchParams.get("app") ?? "dataset";
const tag = Astro.url.searchParams.get("tag");
const res = await fetch(new URL("/data/definitions/" + app + ".json", Astro.url));

if (!res.ok) {
  throw new Error("Failed to load swagger.json");
}

const data = await res.json();

// Helper function to convert schema to TypeScript
async function convertSchemaToTypescript(schema: any, name: string = "Schema"): Promise<string> {
  try {
    const ts = await compile(schema, name, {
      bannerComment: "",
      style: {
        semi: true,
        singleQuote: false,
      },
    });
    return ts;
  } catch (error) {
    return `// Error converting schema: ${error}`;
  }
}

// Group paths by tags
const pathsByTag = new Map<string, Array<{ path: string; method: string; operation: any }>>();

for (const [path, pathItem] of Object.entries(data.paths)) {
  for (const [method, operation] of Object.entries(pathItem as any)) {
    const tags = (operation as any).tags || ["Untagged"];
    for (const tag of tags) {
      if (!pathsByTag.has(tag)) {
        pathsByTag.set(tag, []);
      }
      pathsByTag.get(tag)!.push({ path, method, operation: operation as any });
    }
  }
}

// Pre-convert schemas to TypeScript for each operation
const typescriptSchemas = new Map<string, { input?: string; output?: string }>();
for (const [tag, paths] of pathsByTag) {
  for (const { path, method, operation } of paths) {
    const key = `${method}-${path}`;
    const schemas: { input?: string; output?: string } = {};

    if (operation.requestBody?.content?.["application/vnd.api+json"]?.schema) {
      schemas.input = await convertSchemaToTypescript(
        operation.requestBody.content["application/vnd.api+json"].schema,
        "RequestBody"
      );
    } else if (operation.requestBody?.content?.["application/json"]?.schema) {
      schemas.input = await convertSchemaToTypescript(
        operation.requestBody.content["application/json"].schema,
        "RequestBody"
      );
    }

    const responses = operation.responses || {};
    const successResponse = responses["200"] || responses["201"] || responses["204"];
    if (successResponse?.content?.["application/vnd.api+json"]?.schema) {
      schemas.output = await convertSchemaToTypescript(
        successResponse.content["application/vnd.api+json"].schema,
        "Response"
      );
    } else if (successResponse?.content?.["application/json"]?.schema) {
      schemas.output = await convertSchemaToTypescript(
        successResponse.content["application/json"].schema,
        "Response"
      );
    }

    typescriptSchemas.set(key, schemas);
  }
}
---

<PageLayout>
  <div class="mx-auto max-w-7xl px-4 py-8">
    <h1 class="mb-2 text-4xl font-bold">{data.info.title} API Reference</h1>
    <p class="markdown-content mb-8 text-gray-600">{data.info.description}</p>

    {data.tags.length > 0 ? (
      <div class="space-y-8">
        {data.tags.map((tag: any) => {
          const tagPaths = pathsByTag.get(tag.name) || [];
          return (
            <div id={`tag-${tag.name}`} class="tag-group rounded-lg border border-gray-200 bg-white shadow-sm">
              <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
                <h2 class="text-2xl font-semibold text-gray-900">{tag.name}</h2>
                {tag.description && (
                  <div class="markdown-content mt-1 text-sm text-gray-600" set:html={renderMarkdown(tag.description)} />
                )}
              </div>

              <div class="divide-y divide-gray-100">
                {tagPaths.map(({ path, method, operation }) => {
                  const key = `${method}-${path}`;
                  const tsSchemas = typescriptSchemas.get(key) || {};
                  const methodColor = {
                    get: "bg-blue-500",
                    post: "bg-green-500",
                    put: "bg-yellow-500",
                    patch: "bg-orange-500",
                    delete: "bg-red-500",
                  }[method] || "bg-gray-500";

                  const parameters = operation.parameters || [];
                  const requestBody = operation.requestBody;
                  const responses = operation.responses || {};

                  return (
                    <details class="path-item group">
                      <summary class="flex cursor-pointer items-center gap-4 px-6 py-4 hover:bg-gray-50">
                        <span class={`inline-block w-20 rounded px-2 py-1 text-center text-xs font-bold uppercase text-white ${methodColor}`}>
                          {method}
                        </span>
                        <span class="font-mono text-sm text-gray-900" set:html={highlightPathParams(path)} />
                        {operation.summary && (
                          <span class="text-sm text-gray-600">- {operation.summary}</span>
                        )}
                      </summary>

                      <div class="border-t border-gray-100 bg-gray-50 px-6 py-6">
                        {operation.description && (
                          <div class="mb-6">
                            <h4 class="mb-2 font-semibold text-gray-900">Description</h4>
                            <div class="markdown-content text-sm text-gray-600" set:html={renderMarkdown(operation.description)} />
                          </div>
                        )}

                        {/* Parameters Section */}
                        {parameters.length > 0 && (
                          <div class="mb-6">
                            <h4 class="mb-3 font-semibold text-gray-900">Parameters</h4>
                            <div class="overflow-hidden rounded-lg border border-gray-200">
                              <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-100">
                                  <tr>
                                    <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-600">Name</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-600">In</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-600">Type</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-600">Required</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium uppercase text-gray-600">Description</th>
                                  </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200 bg-white">
                                  {parameters.map((param: any) => (
                                    <tr>
                                      <td class="px-4 py-2 font-mono text-sm text-gray-900">{param.name}</td>
                                      <td class="px-4 py-2 text-sm text-gray-600">{param.in}</td>
                                      <td class="px-4 py-2 font-mono text-sm text-gray-600">{param.schema?.type || "any"}</td>
                                      <td class="px-4 py-2 text-sm">
                                        {param.required ? (
                                          <span class="rounded bg-red-100 px-2 py-1 text-xs text-red-700">Required</span>
                                        ) : (
                                          <span class="rounded bg-gray-100 px-2 py-1 text-xs text-gray-600">Optional</span>
                                        )}
                                      </td>
                                      <td class="px-4 py-2 text-sm text-gray-600">
                                        {param.description ? (
                                          <div class="markdown-content" set:html={renderMarkdown(param.description)} />
                                        ) : "-"}
                                      </td>
                                    </tr>
                                  ))}
                                </tbody>
                              </table>
                            </div>
                          </div>
                        )}

                        {/* Request Body Section */}
                        {requestBody && (
                          <div class="mb-6">
                            <h4 class="mb-3 font-semibold text-gray-900">Input Schema</h4>
                            <div class="rounded-lg border border-gray-200 bg-white">
                              <div class="flex border-b border-gray-200">
                                <button
                                  class="schema-tab active px-4 py-2 text-sm font-medium"
                                  data-target={`input-json-${key}`}
                                  onclick={`switchTab(event, 'input-json-${key}')`}
                                >
                                  Input Schema
                                </button>
                                {tsSchemas.input && (
                                  <button
                                    class="schema-tab px-4 py-2 text-sm font-medium"
                                    data-target={`input-ts-${key}`}
                                    onclick={`switchTab(event, 'input-ts-${key}')`}
                                  >
                                    TypeScript
                                  </button>
                                )}
                              </div>

                              <div class="p-4">
                                <div id={`input-json-${key}`} class="schema-content">
                                  <div
                                    class="json-tree-container"
                                    data-json={JSON.stringify(
                                      requestBody.content?.["application/vnd.api+json"]?.schema ||
                                      requestBody.content?.["application/json"]?.schema || {}
                                    )}
                                  ></div>
                                </div>

                                {tsSchemas.input && (
                                  <div id={`input-ts-${key}`} class="schema-content hidden">
                                    <pre class="ts-code-block"><code class="language-typescript">{tsSchemas.input}</code></pre>
                                  </div>
                                )}
                              </div>
                            </div>
                          </div>
                        )}

                        {/* Response Section */}
                        {Object.keys(responses).length > 0 && (
                          <div class="mb-6">
                            <h4 class="mb-3 font-semibold text-gray-900">Output Schema</h4>

                            {Object.entries(responses).map(([statusCode, response]: [string, any]) => (
                              <div class="mb-4 rounded-lg border border-gray-200 bg-white">
                                <div class="flex items-center border-b border-gray-200 bg-gray-50 px-4 py-2">
                                  <span class={`inline-block rounded px-2 py-1 text-xs font-bold ${
                                    statusCode.startsWith('2') ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'
                                  }`}>
                                    {statusCode}
                                  </span>
                                  {response.description && (
                                    <div class="markdown-content ml-2 text-sm text-gray-600" set:html={renderMarkdown(response.description)} />
                                  )}
                                </div>

                                {response.content && (
                                  <div>
                                    <div class="flex border-b border-gray-200">
                                      <button
                                        class="schema-tab active px-4 py-2 text-sm font-medium"
                                        data-target={`output-json-${key}-${statusCode}`}
                                        onclick={`switchTab(event, 'output-json-${key}-${statusCode}')`}
                                      >
                                        Output Schema
                                      </button>
                                      {tsSchemas.output && statusCode === "200" && (
                                        <button
                                          class="schema-tab px-4 py-2 text-sm font-medium"
                                          data-target={`output-ts-${key}`}
                                          onclick={`switchTab(event, 'output-ts-${key}')`}
                                        >
                                          TypeScript
                                        </button>
                                      )}
                                    </div>

                                    <div class="p-4">
                                      <div id={`output-json-${key}-${statusCode}`} class="schema-content">
                                        <div
                                          class="json-tree-container"
                                          data-json={JSON.stringify(
                                            response.content?.["application/vnd.api+json"]?.schema ||
                                            response.content?.["application/json"]?.schema || {}
                                          )}
                                        ></div>
                                      </div>

                                      {tsSchemas.output && statusCode === "200" && (
                                        <div id={`output-ts-${key}`} class="schema-content hidden">
                                          <pre class="ts-code-block"><code class="language-typescript">{tsSchemas.output}</code></pre>
                                        </div>
                                      )}
                                    </div>
                                  </div>
                                )}
                              </div>
                            ))}
                          </div>
                        )}
                      </div>
                    </details>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="rounded-lg border border-gray-200 bg-white p-8 text-center">
        <p class="text-gray-600">No tags found in spec.</p>
      </div>
    )}
  </div>
</PageLayout>

<style>
  .schema-tab {
    border-bottom: 2px solid transparent;
    color: #6b7280;
    transition: all 0.2s;
  }

  .schema-tab:hover {
    color: #374151;
    background-color: #f9fafb;
  }

  .schema-tab.active {
    color: #2563eb;
    border-bottom-color: #2563eb;
    background-color: white;
  }

  details > summary {
    list-style: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::before {
    content: "▶";
    display: inline-block;
    margin-right: 0.5rem;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  details[open] > summary::before {
    transform: rotate(90deg);
  }

  /* JSON Tree Styles - Global to apply to dynamically generated content */
  :global(.json-tree) {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 13px;
    line-height: 1.8;
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }

  :global(.json-tree-line) {
    display: flex;
    align-items: start;
  }

  :global(.json-tree-line:hover) {
    background-color: rgba(255, 255, 255, 0.05);
  }

  :global(.json-tree-toggle) {
    cursor: pointer;
    user-select: none;
    width: 16px;
    min-width: 16px;
    text-align: left;
    color: #808080;
    flex-shrink: 0;
    line-height: 1.8;
  }

  :global(.json-tree-toggle:hover) {
    color: #cccccc;
  }

  :global(.json-tree-content) {
    flex: 1;
    min-width: 0;
    line-height: 1.8;
  }

  :global(.json-tree-children) {
    margin-left: 16px;
  }

  :global(.json-tree-key) {
    color: #9cdcfe;
  }

  :global(.json-tree-string) {
    color: #ce9178;
  }

  :global(.json-tree-number) {
    color: #b5cea8;
  }

  :global(.json-tree-boolean) {
    color: #569cd6;
  }

  :global(.json-tree-null) {
    color: #569cd6;
  }

  :global(.json-tree-bracket) {
    color: #808080;
  }

  :global(.json-tree-preview) {
    color: #808080;
    font-style: italic;
  }

  /* Prism.js override for TypeScript - Global for dynamic content */
  :global(code[class*="language-"]),
  :global(pre[class*="language-"]) {
    color: #d4d4d4;
    background: none;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 13px;
    text-align: left;
    white-space: pre;
    word-spacing: normal;
    word-break: normal;
    word-wrap: normal;
    line-height: 1.5;
    tab-size: 4;
  }

  :global(.token.comment) { color: #6a9955; }
  :global(.token.keyword) { color: #569cd6; }
  :global(.token.string) { color: #ce9178; }
  :global(.token.number) { color: #b5cea8; }
  :global(.token.boolean) { color: #569cd6; }
  :global(.token.operator) { color: #d4d4d4; }
  :global(.token.punctuation) { color: #808080; }
  :global(.token.class-name) { color: #4ec9b0; }
  :global(.token.function) { color: #dcdcaa; }
  :global(.token.builtin) { color: #4ec9b0; }
  :global(.token.property) { color: #9cdcfe; }
  :global(.token.parameter) { color: #9cdcfe; }
  :global(.token.tag) { color: #569cd6; }

  /* TypeScript code block styling */
  .ts-code-block {
    background: #1e1e1e !important;
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.5;
  }

  /* Dark mode support - Tailwind class-based */
  :global(.dark) .tag-group,
  :global(.dark) .rounded-lg.border {
    background: #1f2937;
    border-color: #374151;
  }

  :global(.dark) .bg-gray-50 {
    background: #111827 !important;
  }

  :global(.dark) .bg-white {
    background: #1f2937 !important;
  }

  :global(.dark) .bg-gray-100 {
    background: #1f2937 !important;
  }

  :global(.dark) .text-gray-900 {
    color: #f3f4f6 !important;
  }

  :global(.dark) .text-gray-600 {
    color: #9ca3af !important;
  }

  :global(.dark) .border-gray-200,
  :global(.dark) .border-b.border-gray-200,
  :global(.dark) .border-t.border-gray-100 {
    border-color: #374151 !important;
  }

  :global(.dark) .divide-gray-100 > *,
  :global(.dark) .divide-gray-200 > * {
    border-color: #374151 !important;
  }

  /* Fix border radius override by rounding tag header corners */
  .tag-group > div:first-child {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
  }

  /* Fix border radius for Input/Output schema containers */
  .rounded-lg > div:first-child {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
  }

  /* Ensure tab buttons respect parent's border radius */
  .rounded-lg > .flex.border-b:first-child .schema-tab:first-child {
    border-top-left-radius: 0.5rem;
  }

  :global(.dark) details > summary:hover {
    background-color: #111827 !important;
  }

  :global(.dark) .schema-tab {
    color: #9ca3af;
  }

  :global(.dark) .schema-tab:hover {
    color: #f3f4f6;
    background-color: #111827;
  }

  :global(.dark) .schema-tab.active {
    color: #60a5fa;
    background-color: #1f2937;
  }

  /* Dark mode - Table styling */
  :global(.dark) thead.bg-gray-100 {
    background: #1f2937 !important;
  }

  :global(.dark) tbody.bg-white {
    background: #111827 !important;
  }

  /* Dark mode - Badge colors */
  :global(.dark) .bg-red-100 {
    background: #7f1d1d !important;
  }

  :global(.dark) .text-red-700 {
    color: #fca5a5 !important;
  }

  :global(.dark) .bg-gray-100 {
    background: #374151 !important;
  }

  :global(.dark) .bg-green-100 {
    background: #14532d !important;
  }

  :global(.dark) .text-green-700 {
    color: #86efac !important;
  }

  /* Markdown content styling */
  :global(.markdown-content) {
    line-height: 1.6;
  }

  :global(.markdown-content p) {
    margin-bottom: 0.75rem;
  }

  :global(.markdown-content p:last-child) {
    margin-bottom: 0;
  }

  :global(.markdown-content ul),
  :global(.markdown-content ol) {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
  }

  :global(.markdown-content li) {
    margin-bottom: 0.25rem;
  }

  :global(.markdown-content code) {
    background: #f3f4f6;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
  }

  :global(.markdown-content pre) {
    background: #f3f4f6;
    padding: 0.75rem;
    border-radius: 0.375rem;
    overflow-x: auto;
    margin-bottom: 0.75rem;
  }

  :global(.markdown-content pre code) {
    background: none;
    padding: 0;
  }

  :global(.markdown-content a) {
    color: #2563eb;
    text-decoration: underline;
  }

  :global(.markdown-content a:hover) {
    color: #1d4ed8;
  }

  :global(.markdown-content strong) {
    font-weight: 600;
  }

  :global(.markdown-content em) {
    font-style: italic;
  }

  :global(.markdown-content h1),
  :global(.markdown-content h2),
  :global(.markdown-content h3),
  :global(.markdown-content h4),
  :global(.markdown-content h5),
  :global(.markdown-content h6) {
    font-weight: 600;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  :global(.markdown-content h1) { font-size: 1.5em; }
  :global(.markdown-content h2) { font-size: 1.25em; }
  :global(.markdown-content h3) { font-size: 1.125em; }

  :global(.markdown-content blockquote) {
    border-left: 4px solid #e5e7eb;
    padding-left: 1rem;
    margin: 0.75rem 0;
    color: #6b7280;
  }

  :global(.markdown-content hr) {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 1rem 0;
  }

  /* Dark mode markdown styling */
  :global(.dark .markdown-content code) {
    background: #374151;
    color: #e5e7eb;
  }

  :global(.dark .markdown-content pre) {
    background: #374151;
  }

  :global(.dark .markdown-content a) {
    color: #60a5fa;
  }

  :global(.dark .markdown-content a:hover) {
    color: #93c5fd;
  }

  :global(.dark .markdown-content blockquote) {
    border-left-color: #4b5563;
    color: #9ca3af;
  }

  :global(.dark .markdown-content hr) {
    border-top-color: #4b5563;
  }
</style>

<script>
  // @ts-ignore - Types are installed but not detected properly by Astro
  import Prism from 'prismjs';
  // @ts-ignore
  import 'prismjs/components/prism-typescript';

  // TypeScript declaration
  declare global {
    interface Window {
      Prism: typeof Prism;
      switchTab: (event: Event, targetId: string) => void;
      toggleJsonNode: (toggle: HTMLElement) => void;
    }
  }

  // Make Prism available globally
  if (typeof window !== 'undefined') {
    window.Prism = Prism;
    // Trigger highlighting after a short delay
    setTimeout(() => {
      Prism.highlightAll();
    }, 100);
  }
</script>

<script is:inline>
  // Tab switching function
  function switchTab(event, targetId) {
    const button = event.currentTarget;
    const container = button.closest('.rounded-lg');

    // Update active tab
    container.querySelectorAll('.schema-tab').forEach(tab => {
      tab.classList.remove('active');
    });
    button.classList.add('active');

    // Show/hide content
    container.querySelectorAll('.schema-content').forEach(content => {
      content.classList.add('hidden');
    });
    const targetContent = document.getElementById(targetId);
    if (targetContent) {
      targetContent.classList.remove('hidden');

      // Re-highlight TypeScript code when switching to TS tab
      setTimeout(() => {
        if (typeof Prism !== 'undefined') {
          const codeBlocks = targetContent.querySelectorAll('code[class*="language-"]');
          codeBlocks.forEach(block => {
            Prism.highlightElement(block);
          });
        }
      }, 50);
    }
  }

  // JSON Tree Renderer
  function createJsonTree(data, isLast = true) {
    if (data === null) {
      return `<span class="json-tree-null">null</span>`;
    }

    if (typeof data !== 'object') {
      if (typeof data === 'string') {
        return `<span class="json-tree-string">"${data}"</span>`;
      }
      if (typeof data === 'number') {
        return `<span class="json-tree-number">${data}</span>`;
      }
      if (typeof data === 'boolean') {
        return `<span class="json-tree-boolean">${data}</span>`;
      }
      return String(data);
    }

    const isArray = Array.isArray(data);
    const entries = Object.entries(data);

    if (entries.length === 0) {
      return isArray ?
        `<span class="json-tree-bracket">[]</span>` :
        `<span class="json-tree-bracket">{}</span>`;
    }

    const openBracket = isArray ? '[' : '{';
    const closeBracket = isArray ? ']' : '}';

    let html = `<span class="json-tree-bracket">${openBracket}</span>\n`;

    entries.forEach(([key, value], index) => {
      const isLastItem = index === entries.length - 1;
      const hasChildren = value !== null && typeof value === 'object' && Object.keys(value).length > 0;

      html += '<div class="json-tree-line">';
      html += '<div class="json-tree-toggle">';

      if (hasChildren) {
        html += `<span onclick="toggleJsonNode(this)" style="cursor: pointer;">▶</span>`;
      } else {
        html += `<span style="opacity: 0; cursor: default;">▶</span>`;
      }

      html += '</div><div class="json-tree-content">';

      if (!isArray) {
        html += `<span class="json-tree-key">"${key}"</span>: `;
      }

      if (hasChildren) {
        html += `<span class="json-tree-preview">${Array.isArray(value) ? '[...]' : '{...}'}</span>`;
        html += `<div class="json-tree-children" style="display: none;">`;
        html += createJsonTree(value, isLastItem);
        html += `</div>`;
      } else {
        html += createJsonTree(value, isLastItem);
      }

      if (!isLastItem) {
        html += '<span class="json-tree-bracket">,</span>';
      }

      html += '</div></div>\n';
    });

    html += `<span class="json-tree-bracket">${closeBracket}</span>`;

    return html;
  }

  function toggleJsonNode(toggle) {
    const line = toggle.closest('.json-tree-line');
    if (!line) return;

    const content = line.querySelector('.json-tree-content');
    if (!content) return;

    const children = content.querySelector('.json-tree-children');
    const preview = content.querySelector('.json-tree-preview');

    if (children && preview) {
      const isExpanded = children.style.display !== 'none';

      if (isExpanded) {
        children.style.display = 'none';
        preview.style.display = 'inline';
        toggle.textContent = '▶';
      } else {
        children.style.display = 'block';
        preview.style.display = 'none';
        toggle.textContent = '▼';
      }
    }
  }

  // Initialize JSON trees
  function initJsonTrees() {
    document.querySelectorAll('.json-tree-container').forEach(container => {
      const jsonData = JSON.parse(container.dataset.json);
      const treeHtml = createJsonTree(jsonData);
      container.innerHTML = `<div class="json-tree">${treeHtml}</div>`;
    });
  }

  // Syntax highlighting for TypeScript
  function highlightTypeScript() {
    if (typeof Prism !== 'undefined') {
      Prism.highlightAll();
    }
  }

  // Scroll to tag if specified in URL
  function scrollToTag() {
    const urlParams = new URLSearchParams(window.location.search);
    const tagParam = urlParams.get('tag');

    if (tagParam) {
      const tagElement = document.getElementById(`tag-${tagParam}`);
      if (tagElement) {
        setTimeout(() => {
          const elementPosition = tagElement.getBoundingClientRect().top + window.pageYOffset;
          const offsetPosition = elementPosition - 80; // 80px offset from top

          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }, 200);
      }
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initJsonTrees();
      highlightTypeScript();
      scrollToTag();
    });
  } else {
    initJsonTrees();
    highlightTypeScript();
    scrollToTag();
  }

  // Make functions available globally
  window.switchTab = switchTab;
  window.toggleJsonNode = toggleJsonNode;
</script>
