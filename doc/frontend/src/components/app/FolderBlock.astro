---
interface FolderItem {
  name: string;
  type: 'file' | 'folder';
  comment?: string;
  children?: FolderItem[];
}

interface Props {
  title?: string;
  structure: FolderItem[];
}

const { title, structure } = Astro.props;

// Helper to calculate display width (excluding HTML tags)
function getDisplayWidth(items: FolderItem[], depth: number = 0): number {
  let maxWidth = 0;

  items.forEach((item) => {
    const treePrefix = depth === 0 ? 0 : (depth * 4 + 4); // Each level adds 4 chars, plus 4 for ├── or └──
    const iconWidth = 2; // Icon + space
    const nameWidth = item.name.length;
    const totalWidth = treePrefix + iconWidth + nameWidth;

    maxWidth = Math.max(maxWidth, totalWidth);

    if (item.children && item.children.length > 0) {
      maxWidth = Math.max(maxWidth, getDisplayWidth(item.children, depth + 1));
    }
  });

  return maxWidth;
}

function renderTree(items: FolderItem[], isLast: boolean[] = [], maxWidth: number, depth: number = 0): string {
  let output = '';

  items.forEach((item, index) => {
    const isLastItem = index === items.length - 1;
    const currentIsLast = [...isLast, isLastItem];
    const isRoot = isLast.length === 0;

    // Build the tree line prefix with gray styling
    let line = '';
    if (!isRoot) {
      line += '<span class="tree-lines">';
      for (let i = 0; i < isLast.length; i++) {
        line += isLast[i] ? '   ' : '│  ';
      }
      line += isLastItem ? '└─ ' : '├─ ';
      line += '</span>';
    }

    // Escape HTML entities (escape & first, then < and >)
    const escapeName = (str: string) => str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    // Add icon with color (using SVG for both folder and file)
    const icon = item.type === 'folder'
      ? '<svg class="folder-icon" fill="currentColor" viewBox="0 0 20 20" style="width:0.875rem;height:0.875rem;display:inline-block;vertical-align:middle;margin-right:0.25rem;"><path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"></path></svg>'
      : '<svg class="file-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width:0.875rem;height:0.875rem;display:inline-block;vertical-align:middle;margin-right:0.25rem;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>';

    // Style the name based on type
    const styledName = item.type === 'folder'
      ? `<span class="folder-name">${escapeName(item.name)}</span>`
      : `<span class="file-name">${escapeName(item.name)}</span>`;

    // Calculate padding for comment alignment (add depth-based indentation)
    const currentWidth = line.replace(/<[^>]*>/g, '').length + 2 + item.name.length; // tree prefix + icon + name
    const baseCommentColumn = maxWidth + 2;
    const commentIndent = depth * 3; // Add 2 spaces per depth level
    const targetColumn = baseCommentColumn + commentIndent;
    const padding = ' '.repeat(Math.max(2, targetColumn - currentWidth));

    // Add comment if exists
    const comment = item.comment ? `${padding}<span class="comment"># ${escapeName(item.comment)}</span>` : '';

    // Build the complete line
    output += `${line}${icon}${styledName}${comment}\n`;

    // Render children if any
    if (item.children && item.children.length > 0) {
      output += renderTree(item.children, currentIsLast, maxWidth, depth + 1);
    }
  });

  return output;
}

const maxWidth = getDisplayWidth(structure);
const treeText = renderTree(structure, [], maxWidth);
---

<div class="relative">
  {title && (
    <div class="bg-gray-800 text-gray-300 px-4 py-2 text-sm font-mono rounded-t-lg border-b border-gray-700 flex items-center gap-2">
      <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"></path>
      </svg>
      <span>{title}</span>
    </div>
  )}
  <pre class:list={["folder-block", title && "!rounded-t-none rounded-b-lg"]} set:html={treeText}></pre>
</div>

<style>
  .folder-block {
    background-color: #111827;
    color: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.875rem;
    line-height: 1.2;
    overflow-x: auto;
    margin: 0;
  }

  .folder-block :global(.tree-lines) {
    color: #9ca3af; /* gray-400 */
  }

  .folder-block :global(.folder-icon) {
    color: #fbbf24 !important; /* yellow-400 */
  }

  .folder-block :global(.file-icon) {
    color: #9ca3af !important; /* gray-400 */
  }

  .folder-block :global(.folder-name) {
    color: #60a5fa !important; /* blue-400 */
    font-weight: 500;
  }

  .folder-block :global(.file-name) {
    color: #d1d5db !important; /* gray-300 */
  }

  .folder-block :global(.comment) {
    color: #6b7280 !important; /* gray-500 */
    font-style: italic;
  }
</style>
