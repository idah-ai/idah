---
import Logo from "@components/app/brands/Logo.astro";

import { Separator } from "$lib/components/ui/separator";
import { Button } from "$lib/components/ui/button";
import SidebarToggleButton from "$lib/app/button/sidebar-toggle-button.svelte";
import SearchBar from "$lib/app/bar/search-bar.svelte";
import SearchIconButton from "$lib/app/button/search-icon-button.svelte";
import { Download } from '@lucide/astro';
import ModeSwitcher from "./app/switchers/ModeSwitcher.astro";
---

<header id="header" class="bg-white dark:bg-gray-950 fixed top-0 left-0 z-50 h-16 w-full border-b px-4 shadow-md" style="border-bottom-color: #2391ea33;">
  <div class="mx-auto flex h-full w-full items-center gap-3">
    <!-- left -->
    <a href="/" class="hover:opacity-80 transition-opacity">
      <div class="flex shrink-0 items-center">
          <Logo id="header-logo" />

        <Separator orientation="vertical" class="ml-3 h-6 mx-3 bg-blue-200 dark:bg-blue-700" />
        <div class="hidden text-lg font-bold sm:block" style="background: linear-gradient(to right, #2391ea, #1e7ac9); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Docs
        </div>
      </div>
    </a>

    <SearchBar client:load />

    <!-- right -->
    <div class="ml-auto flex shrink-0 items-center gap-3">
      <SearchIconButton client:load />

      <div class="flex items-center pb-3 sm:pb-0">
        <ModeSwitcher />
      </div>

      <Button
        href="/install"
        class="hidden lg:flex text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-105 border-0"
        style="background: linear-gradient(to right, #2391ea, #1e7ac9);"
      >
        <Download class="w-4 h-4" stroke-width={2} />
        Install IDAH
      </Button>

      <SidebarToggleButton client:load />
    </div>
  </div>
</header>
