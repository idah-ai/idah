---
import "@styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/idah-logo-favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>IDAH Data Annotation</title>
  </head>

  <body class="min-h-screen overflow-x-hidden">
    <slot />
  </body>
</html>

<script>
  // @ts-ignore - Types are installed but not detected properly by Astro
  import Prism from 'prismjs';
  // @ts-ignore
  import 'prismjs/components/prism-bash';
  // @ts-ignore
  import 'prismjs/components/prism-typescript';
  // @ts-ignore
  import 'prismjs/components/prism-javascript';
  // @ts-ignore
  import 'prismjs/components/prism-json';
  // @ts-ignore
  import 'prismjs/components/prism-css';
  // @ts-ignore
  import 'prismjs/components/prism-ruby';
  // @ts-ignore
  import 'prism-svelte';
  import { marked } from 'marked';

  // TypeScript declaration
  declare global {
    interface Window {
      Prism: typeof Prism;
      marked: typeof marked;
    }
  }

  // Configure marked for safe rendering
  marked.setOptions({
    breaks: true,
    gfm: true,
  });

  // Make Prism and marked available globally
  if (typeof window !== 'undefined') {
    window.Prism = Prism;
    window.marked = marked;

    // Trigger highlighting after a short delay and on page navigation
    const highlightCode = () => {
      setTimeout(() => {
        Prism.highlightAll();
      }, 100);
    };

    // Initial highlight
    highlightCode();

    // Re-highlight on Astro page navigation
    document.addEventListener('astro:after-swap', highlightCode);
  }
</script>
