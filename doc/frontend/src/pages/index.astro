---
import PageLayout from "@layouts/PageLayout.astro";
import PageContainer from "@components/app/page/PageContainer.astro";
import HeroSection from "@components/app/section/HeroSection.astro";
import { Button } from "$lib/components/ui/button";
import { Sparkles, Zap, Shield, Puzzle, Users, ArrowRight, BookOpen, Download, Layers } from "@lucide/astro";
---

<PageLayout>
  <PageContainer>
    <div class="relative mt-8 mb-16 overflow-hidden text-center">
      <HeroSection />

      <div class="mb-6 flex justify-center">
        <div class="rounded-2xl p-4 shadow-xl" style="background: linear-gradient(to bottom right, #2391ea, #1e7ac9);">
          <Layers class="h-16 w-16 text-white" stroke-width={2} />
        </div>
      </div>
      <h1 class="mb-4 text-5xl font-extrabold text-gray-900 md:text-6xl dark:text-white">
        Welcome to <span
          style="background: linear-gradient(to right, #2391ea, #1e7ac9); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
          >IDAH</span
        > Docs
      </h1>
      <p class="mb-2 text-2xl text-gray-600 dark:text-gray-400">Ingedata Annotation Hub</p>
      <p class="mx-auto mb-8 max-w-3xl text-xl leading-relaxed text-gray-700 dark:text-gray-300">
        An open-source platform for collaborative data annotation, designed to streamline the creation of high-quality
        training datasets for machine learning models.
      </p>

      <!-- CTA Buttons -->
      <div class="mb-12 flex flex-wrap justify-center gap-4">
        <Button
          href="/getting-started/about/"
          class="inline-flex items-center gap-2 rounded-lg py-6 font-semibold shadow-lg transition-all hover:shadow-xl"
          size="lg"
          variant="outline"
        >
          <BookOpen class="h-5 w-5" stroke-width={2} />
          Learn More
        </Button>
        <Button
          href="/install/"
          class="inline-flex items-center gap-2 rounded-lg py-6 font-semibold text-white shadow-lg transition-all hover:shadow-xl"
          style="background: linear-gradient(to right, #2391ea, #1e7ac9);"
          size="lg"
        >
          <Download class="h-5 w-5" stroke-width={2} />
          Get Started
        </Button>
      </div>
    </div>

    <!-- Key Highlights -->
    <div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      <div
        class="rounded-xl border-2 border-blue-200 bg-white p-6 transition-all duration-300 hover:shadow-2xl dark:border-blue-800 dark:bg-gray-800"
      >
        <div
          class="mb-4 inline-block rounded-xl p-3 shadow-md"
          style="background: linear-gradient(to bottom right, rgba(35, 145, 234, 0.1), rgba(35, 145, 234, 0.2));"
        >
          <Sparkles class="h-7 w-7" style="color: #2391ea;" stroke-width={2} />
        </div>
        <h3 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Multi-Modal</h3>
        <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
          Support for images, videos, audio, text, and custom data types through an extensible plugin system.
        </p>
      </div>

      <div
        class="rounded-xl border-2 border-green-200 bg-white p-6 transition-all duration-300 hover:shadow-2xl dark:border-green-800 dark:bg-gray-800"
      >
        <div
          class="mb-4 inline-block rounded-xl bg-gradient-to-br from-green-100 to-green-200 p-3 shadow-md dark:from-green-900/30 dark:to-green-800/30"
        >
          <Users class="h-7 w-7 text-green-600 dark:text-green-400" stroke-width={2} />
        </div>
        <h3 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Collaborative</h3>
        <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
          Team-based workflows with role management, task assignments, and multi-stage review processes.
        </p>
      </div>

      <div
        class="rounded-xl border-2 border-purple-200 bg-white p-6 transition-all duration-300 hover:shadow-2xl dark:border-purple-800 dark:bg-gray-800"
      >
        <div
          class="mb-4 inline-block rounded-xl bg-gradient-to-br from-purple-100 to-purple-200 p-3 shadow-md dark:from-purple-900/30 dark:to-purple-800/30"
        >
          <Puzzle class="h-7 w-7 text-purple-600 dark:text-purple-400" stroke-width={2} />
        </div>
        <h3 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Extensible</h3>
        <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
          Powerful plugin system for custom annotation tools, media processors, and export formats.
        </p>
      </div>

      <div
        class="rounded-xl border-2 border-orange-200 bg-white p-6 transition-all duration-300 hover:shadow-2xl dark:border-orange-800 dark:bg-gray-800"
      >
        <div
          class="mb-4 inline-block rounded-xl bg-gradient-to-br from-orange-100 to-orange-200 p-3 shadow-md dark:from-orange-900/30 dark:to-orange-800/30"
        >
          <Shield class="h-7 w-7 text-orange-600 dark:text-orange-400" stroke-width={2} />
        </div>
        <h3 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Enterprise-Ready</h3>
        <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
          Built-in audit logging, compliance tracking, and scalable microservices architecture.
        </p>
      </div>
    </div>

    <!-- Quick Navigation -->
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2 class="mb-6 text-3xl font-bold text-gray-900 dark:text-white">Quick Start Guide</h2>

      <div class="not-prose mb-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        <a
          href="/getting-started/about/"
          class="group block rounded-xl p-8 shadow-lg transition-all duration-300 hover:shadow-2xl"
          style="background: linear-gradient(135deg, rgba(35, 145, 234, 0.08) 0%, rgba(30, 122, 201, 0.08) 100%);"
        >
          <div class="flex flex-col items-center gap-4 text-center">
            <div
              class="rounded-full p-4 shadow-lg"
              style="background: linear-gradient(to bottom right, #2391ea, #1e7ac9);"
            >
              <BookOpen class="h-8 w-8 text-white" stroke-width={2.5} />
            </div>
            <div>
              <h3 class="mb-2 text-2xl font-bold text-gray-900 dark:text-white">Learn</h3>
              <p class="mb-4 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                Understand the architecture, features, and capabilities of the platform.
              </p>
              <div
                class="inline-flex items-center gap-2 text-sm font-bold transition-all group-hover:gap-3"
                style="color: #2391ea;"
              >
                Read More <ArrowRight class="h-4 w-4" stroke-width={2.5} />
              </div>
            </div>
          </div>
        </a>

        <a
          href="/install/"
          class="group block rounded-xl p-8 shadow-lg transition-all duration-300 hover:shadow-2xl"
          style="background: linear-gradient(135deg, rgba(34, 197, 94, 0.08) 0%, rgba(20, 184, 166, 0.08) 100%);"
        >
          <div class="flex flex-col items-center gap-4 text-center">
            <div class="rounded-full bg-gradient-to-br from-green-500 to-teal-600 p-4 shadow-lg">
              <Download class="h-8 w-8 text-white" stroke-width={2.5} />
            </div>
            <div>
              <h3 class="mb-2 text-2xl font-bold text-gray-900 dark:text-white">Install</h3>
              <p class="mb-4 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                Follow step-by-step instructions to set up IDAH on your local machine or server.
              </p>
              <div
                class="inline-flex items-center gap-2 text-sm font-bold text-green-600 transition-all group-hover:gap-3 dark:text-green-400"
              >
                Install Now <ArrowRight class="h-4 w-4" stroke-width={2.5} />
              </div>
            </div>
          </div>
        </a>

        <a
          href="/plugin/"
          class="group block rounded-xl p-8 shadow-lg transition-all duration-300 hover:shadow-2xl"
          style="background: linear-gradient(135deg, rgba(168, 85, 247, 0.08) 0%, rgba(192, 132, 252, 0.08) 100%);"
        >
          <div class="flex flex-col items-center gap-4 text-center">
            <div class="rounded-full bg-gradient-to-br from-purple-500 to-purple-400 p-4 shadow-lg">
              <Puzzle class="h-8 w-8 text-white" stroke-width={2.5} />
            </div>
            <div>
              <h3 class="mb-2 text-2xl font-bold text-gray-900 dark:text-white">Extend</h3>
              <p class="mb-4 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                Create custom plugins to add specialized annotation tools and workflows.
              </p>
              <div
                class="inline-flex items-center gap-2 text-sm font-bold text-purple-600 transition-all group-hover:gap-3 dark:text-purple-400"
              >
                Create Plugins <ArrowRight class="h-4 w-4" stroke-width={2.5} />
              </div>
            </div>
          </div>
        </a>
      </div>

      <h2 class="mb-6 text-3xl font-bold text-gray-900 dark:text-white">Why Choose IDAH?</h2>

      <div class="not-prose mb-12 grid grid-cols-1 gap-4 md:grid-cols-2">
        <div
          class="rounded-xl border border-gray-200 bg-white p-6 shadow-md transition-all duration-300 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800"
        >
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 text-3xl font-bold" style="color: #2391ea;">✓</span>
            <div>
              <h4 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Open Source</h4>
              <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                Free to use, modify, and distribute under <a
                  href="https://github.com/idah-ai/idah/blob/main/LICENSE"
                  class="text-blue-600 hover:underline dark:text-blue-400"
                  target="_blank"
                  rel="noopener noreferrer">Mozilla Public License 2.0</a
                >
              </p>
            </div>
          </div>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 shadow-md transition-all duration-300 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800"
        >
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 text-3xl font-bold" style="color: #2391ea;">✓</span>
            <div>
              <h4 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Microservices Architecture</h4>
              <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                Scalable and maintainable with independent services
              </p>
            </div>
          </div>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 shadow-md transition-all duration-300 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800"
        >
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 text-3xl font-bold" style="color: #2391ea;">✓</span>
            <div>
              <h4 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Modern Tech Stack</h4>
              <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                Built with SvelteKit, Ruby Verse Framework, PostgreSQL, and Redis
              </p>
            </div>
          </div>
        </div>

        <div
          class="rounded-xl border border-gray-200 bg-white p-6 shadow-md transition-all duration-300 hover:shadow-xl dark:border-gray-700 dark:bg-gray-800"
        >
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 text-3xl font-bold" style="color: #2391ea;">✓</span>
            <div>
              <h4 class="mb-2 text-lg font-bold text-gray-900 dark:text-white">Plugin Ecosystem</h4>
              <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                Extend functionality without modifying core code
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="relative overflow-hidden rounded-2xl border border-gray-200 p-10 text-center shadow-lg transition-all duration-300 hover:shadow-xl dark:border-gray-700"
        style="background: linear-gradient(135deg, rgba(35, 145, 234, 0.05) 0%, rgba(30, 122, 201, 0.08) 100%);"
      >
        <div
          class="absolute top-0 right-0 h-96 w-96 rounded-full opacity-10"
          style="background: radial-gradient(circle, #2391ea 0%, transparent 70%); transform: translate(40%, -40%);"
        >
        </div>
        <div
          class="absolute bottom-0 left-0 h-80 w-80 rounded-full opacity-10"
          style="background: radial-gradient(circle, #2391ea 0%, transparent 70%); transform: translate(-40%, 40%);"
        >
        </div>
        <div class="relative">
          <div class="mb-4 flex justify-center">
            <div
              class="rounded-full p-3 shadow-md"
              style="background: linear-gradient(to bottom right, rgba(35, 145, 234, 0.15), rgba(35, 145, 234, 0.25));"
            >
              <Zap class="h-10 w-10" style="color: #2391ea;" stroke-width={2.5} />
            </div>
          </div>
          <h3 class="mb-4 text-3xl font-extrabold text-gray-900 dark:text-white">Ready to Start Annotating?</h3>
          <p class="mx-auto mb-8 max-w-2xl text-xl leading-relaxed text-gray-700 dark:text-gray-300">
            Set up IDAH in minutes and begin creating high-quality datasets for your ML projects.
          </p>
          <a
            href="/install/"
            class="inline-flex items-center gap-3 rounded-xl px-8 py-4 font-bold text-white shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl"
            style="background: linear-gradient(to right, #2391ea, #1e7ac9);"
          >
            <Download class="h-6 w-6" stroke-width={2.5} />
            Install IDAH Now
          </a>
        </div>
      </div>
    </div>
  </PageContainer>
</PageLayout>
