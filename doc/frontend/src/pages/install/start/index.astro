---
import PageLayout from "@layouts/PageLayout.astro";
import Pagination from "@components/app/page/Pagination.astro";
import PageContainer from "@components/app/page/PageContainer.astro";
import PageTitle from "@components/app/page/PageTitle.astro";
import CodeBlock from "@components/app/CodeBlock.astro";
import { Rocket } from "@lucide/astro";
---

<PageLayout>
  <PageContainer>
    <PageTitle>
      <div class="rounded-xl bg-green-50 p-3 text-green-500 dark:bg-green-900/20 dark:text-green-700">
        <Rocket class="h-9 w-9" stroke-width={2} />
      </div>
      Start IDAH
    </PageTitle>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <p class="mb-8 text-lg leading-relaxed text-gray-700 dark:text-gray-300">
        Build and run the IDAH platform using Docker Compose.
      </p>

      <h2
        id="start-services"
        class="mt-12 mb-6 border-b-2 border-gray-200 pb-3 text-3xl font-bold text-gray-900 dark:border-gray-700 dark:text-white"
      >
        <a href="#start-services" class="hover:underline">Start IDAH Services</a>
      </h2>

      <h3 id="build-and-start" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#build-and-start" class="hover:underline">1. Build and Start Containers</a>
      </h3>
      <p class="mb-4 leading-relaxed text-gray-700 dark:text-gray-300">
        From the project root directory, start all IDAH services:
      </p>
      <CodeBlock language="bash" code={`docker compose up -d`} />
      <p class="mb-6 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
        This builds and starts all microservices (frontend, IAM, dataset, media, sync, notification, audit, setting) and
        the nginx gateway.
      </p>

      <h3 id="first-time-setup" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#first-time-setup" class="hover:underline">2. First-Time Setup</a>
      </h3>
      <p class="mb-4 leading-relaxed text-gray-700 dark:text-gray-300">
        For the first time setup, run this command to create service accounts and a default Admin User:
      </p>
      <CodeBlock language="bash" code={`docker compose run iam bundle exec rake dev:setup dev:users`} />

      <div class="mb-6 rounded-r border-l-4 border-green-500 bg-green-50 p-4 dark:bg-green-900/20">
        <p class="mb-2 text-sm font-semibold text-gray-800 dark:text-gray-200">Default Admin Credentials</p>
        <ul class="space-y-1 text-sm text-gray-700 dark:text-gray-300">
          <li>
            <strong>Email:</strong>
            <code class="rounded bg-gray-100 px-2 py-0.5 dark:bg-gray-800">admin@idah.ai</code>
          </li>
          <li>
            <strong>Password:</strong>
            <code class="rounded bg-gray-100 px-2 py-0.5 dark:bg-gray-800">P@ssword01</code>
          </li>
        </ul>
      </div>

      <h3 id="access-idah" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#access-idah" class="hover:underline">3. Access IDAH</a>
      </h3>
      <p class="mb-4 leading-relaxed text-gray-700 dark:text-gray-300">Open your browser and navigate to:</p>
      <div class="mb-6 rounded-r border-l-4 border-blue-500 bg-blue-50 p-4 dark:bg-blue-900/20">
        <p class="mb-2 text-sm font-semibold text-gray-800 dark:text-gray-200">IDAH URL</p>
        <p class="text-sm text-gray-700 dark:text-gray-300">
          <a
            href="https://idah.localhost:8443"
            class="text-blue-600 hover:underline dark:text-blue-400"
            target="_blank"
            rel="noopener noreferrer">https://idah.localhost:8443</a
          >
        </p>
      </div>
      <p class="mb-6 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
        Log in using the default admin credentials above.
      </p>

      <h2
        id="verify-installation"
        class="mt-12 mb-6 border-b-2 border-gray-200 pb-3 text-3xl font-bold text-gray-900 dark:border-gray-700 dark:text-white"
      >
        <a href="#verify-installation" class="hover:underline">Verify Installation</a>
      </h2>

      <h3 id="check-services" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#check-services" class="hover:underline">Check Running Services</a>
      </h3>
      <CodeBlock language="bash" code={`docker compose ps`} />
      <p class="mb-6 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
        All services should show status as "running".
      </p>

      <h3 id="view-logs" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#view-logs" class="hover:underline">View Logs</a>
      </h3>
      <CodeBlock language="bash" code={`# View all service logs
docker compose logs -f

# View specific service logs
docker compose logs -f frontend
docker compose logs -f iam
docker compose logs -f media`} />

      <h2
        id="common-commands"
        class="mt-12 mb-6 border-b-2 border-gray-200 pb-3 text-3xl font-bold text-gray-900 dark:border-gray-700 dark:text-white"
      >
        <a href="#common-commands" class="hover:underline">Common Commands</a>
      </h2>

      <h3 id="stop-services" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#stop-services" class="hover:underline">Stop Services</a>
      </h3>
      <CodeBlock language="bash" code={`docker compose down`} />

      <h3 id="restart-services" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#restart-services" class="hover:underline">Restart Services</a>
      </h3>
      <CodeBlock language="bash" code={`# Restart all services
docker compose restart

# Restart specific service
docker compose restart frontend`} />

      <h3 id="rebuild-services" class="mt-8 mb-4 text-2xl font-semibold text-gray-800 dark:text-gray-200">
        <a href="#rebuild-services" class="hover:underline">Rebuild Services</a>
      </h3>
      <CodeBlock language="bash" code={`# Rebuild and restart all services
docker compose up -d --build

# Rebuild specific service
docker compose up -d --build frontend`} />

      <h2
        id="next-steps"
        class="mt-12 mb-6 border-b-2 border-gray-200 pb-3 text-3xl font-bold text-gray-900 dark:border-gray-700 dark:text-white"
      >
        <a href="#next-steps" class="hover:underline">Next Steps</a>
      </h2>
      <p class="mb-4 leading-relaxed text-gray-700 dark:text-gray-300">Now that IDAH is running, you can:</p>
      <ul class="mb-6 list-inside list-disc space-y-2 text-gray-700 dark:text-gray-300">
        <li class="leading-relaxed">Log in with the default admin credentials</li>
        <li class="leading-relaxed">Create your first dataset</li>
        <li class="leading-relaxed">Explore the annotation tools</li>
        <li class="leading-relaxed">
          <a href="/plugin/create-plugin/" class="text-blue-600 hover:underline dark:text-blue-400">Create a Plugin</a> -
          Build custom annotation plugins
        </li>
      </ul>

      <div
        class="mb-6 rounded-lg border-l-4 border-blue-500 bg-gradient-to-r from-blue-50 to-purple-50 p-6 dark:from-blue-900/20 dark:to-purple-900/20"
      >
        <p class="text-lg leading-relaxed font-medium text-gray-800 dark:text-gray-200">
          🚀 IDAH is now running! Access it at <a
            href="https://idah.localhost:8443"
            class="font-semibold text-blue-600 hover:underline dark:text-blue-400">https://idah.localhost:8443</a
          >
        </p>
      </div>
    </div>
  </PageContainer>
  <Pagination />
</PageLayout>
