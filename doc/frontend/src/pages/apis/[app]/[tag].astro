---
import { getApiUrls } from "$lib/app/sidebar/api-urls";
import CodeBlock from "@components/app/CodeBlock.astro";
import PageContainer from "@components/app/page/PageContainer.astro";
import PageTitle from "@components/app/page/PageTitle.astro";
import Pagination from "@components/app/page/Pagination.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { Braces } from "@lucide/svelte";
import { compile } from "json-schema-to-typescript";
import { marked } from "marked";

export async function getStaticPaths() {
  const urls = await getApiUrls();

  const mappedUrls: Array<{ params: { app: string; tag: string } }> = [];

  urls.forEach((item) => {
    item.tags?.forEach((tag) => {
      mappedUrls.push({
        params: {
          app: item.name,
          tag,
        },
      });
    });
  });

  return mappedUrls;
}

// Configure marked for safe rendering
marked.setOptions({
  breaks: true,
  gfm: true,
});

// Helper to render markdown safely
function renderMarkdown(text: string): string {
  if (!text) return "";
  return marked.parse(text) as string;
}

// Helper to highlight path parameters
function highlightPathParams(path: string): string {
  return path.replace(/\{([^}]+)\}/g, "<b>{$1}</b>");
}

// Helper to convert JSON Schema to example JSON
function schemaToExampleJSON(schema: any): any {
  if (!schema || typeof schema !== "object") return null;

  const type = schema.type;

  // Return example or default if provided
  if (schema.example !== undefined) return schema.example;
  if (schema.default !== undefined) return schema.default;

  // Handle enum
  if (schema.enum && schema.enum.length > 0) return schema.enum[0];

  // Any of type
  if (schema.anyOf && Array.isArray(schema.anyOf)) {
    // Just use the first option for example
    return schemaToExampleJSON(schema.anyOf[0]);
  }

  // Handle different types
  switch (type) {
    case "object":
      const obj: any = {};
      if (schema.properties) {
        for (const [key, propSchema] of Object.entries(schema.properties)) {
          obj[key] = schemaToExampleJSON(propSchema as any);
        }
      }
      return obj;

    case "array":
      if (schema.items) {
        return [schemaToExampleJSON(schema.items)];
      }
      return [];

    case "string":
      // Check for format-specific examples
      if (schema.format === "date-time") {
        return new Date().toISOString();
      }
      if (schema.format === "date") {
        return new Date().toISOString().split("T")[0];
      }
      if (schema.format === "email") {
        return "user@example.com";
      }
      if (schema.format === "uuid") {
        return "123e4567-e89b-12d3-a456-426614174000";
      }
      return "string";

    case "number":
    case "integer":
      return 0;

    case "boolean":
      return false;

    case "null":
      return null;

    default:
      // If no type specified but has properties, treat as object
      if (schema.properties) {
        const obj: any = {};
        for (const [key, propSchema] of Object.entries(schema.properties)) {
          obj[key] = schemaToExampleJSON(propSchema as any);
        }
        return obj;
      }
      return {};
  }
}

const { app, tag } = Astro.params;

let data;
// During build (SSR), read from filesystem
if (import.meta.env.SSR) {
  const fs = await import("node:fs/promises");
  const path = await import("node:path");
  const filePath = path.join(process.cwd(), "public", "data", "definitions", `${app}.json`);
  const content = await fs.readFile(filePath, "utf-8");
  data = JSON.parse(content);
} else {
  // In browser, use fetch
  const res = await fetch(`/data/definitions/${app}.json`);
  if (!res.ok) {
    throw new Error("Failed to load definition file");
  }
  data = await res.json();
}

// Helper function to convert schema to TypeScript
async function convertSchemaToTypescript(schema: any, name: string = "Schema"): Promise<string> {
  try {
    const ts = await compile(schema, name, {
      bannerComment: "",
      style: {
        semi: true,
        singleQuote: false,
      },
    });
    return ts;
  } catch (error) {
    return `// Error converting schema: ${error}`;
  }
}

// Group paths by tags
const pathsByTag = new Map<string, Array<{ path: string; method: string; operation: any }>>();

for (const [path, pathItem] of Object.entries(data.paths)) {
  for (const [method, operation] of Object.entries(pathItem as any)) {
    const tags = (operation as any).tags || ["Untagged"];
    for (const tag of tags) {
      if (!pathsByTag.has(tag)) {
        pathsByTag.set(tag, []);
      }
      pathsByTag.get(tag)!.push({ path, method, operation: operation as any });
    }
  }
}

// Pre-convert schemas to TypeScript for each operation
const typescriptSchemas = new Map<string, { input?: string; output?: string }>();
for (const [tag, paths] of pathsByTag) {
  for (const { path, method, operation } of paths) {
    const key = `${method}-${path}`;
    const schemas: { input?: string; output?: string } = {};

    if (operation.requestBody?.content?.["application/vnd.api+json"]?.schema) {
      schemas.input = await convertSchemaToTypescript(
        operation.requestBody.content["application/vnd.api+json"].schema,
        "RequestBody",
      );
    } else if (operation.requestBody?.content?.["application/json"]?.schema) {
      schemas.input = await convertSchemaToTypescript(
        operation.requestBody.content["application/json"].schema,
        "RequestBody",
      );
    } else if (operation.requestBody?.content?.["multipart/form-data"]?.schema) {
      schemas.input = await convertSchemaToTypescript(
        operation.requestBody.content["multipart/form-data"].schema,
        "RequestBody",
      );
    }

    const responses = operation.responses || {};
    const successResponse = responses["200"] || responses["201"] || responses["204"];
    if (successResponse?.content?.["application/vnd.api+json"]?.schema) {
      schemas.output = await convertSchemaToTypescript(
        successResponse.content["application/vnd.api+json"].schema,
        "Response",
      );
    } else if (successResponse?.content?.["application/json"]?.schema) {
      schemas.output = await convertSchemaToTypescript(successResponse.content["application/json"].schema, "Response");
    } else if (successResponse?.content?.["multipart/form-data"]?.schema) {
      schemas.output = await convertSchemaToTypescript(
        successResponse.content["multipart/form-data"].schema,
        "Response",
      );
    }

    typescriptSchemas.set(key, schemas);
  }
}
---

<PageLayout>
  <div data-pagefind-ignore>
    <PageContainer>
      <PageTitle>
        <div class="rounded-xl bg-blue-50 p-3 text-blue-400 dark:bg-blue-900/20 dark:text-blue-600">
          <Braces class="h-9 w-9" stroke-width={2} />
        </div>
        {data.info.title} API Reference
      </PageTitle>
      <div class="mb-6" data-tag={tag}>
        <p class="markdown-content mb-8 text-gray-600">{data.info.description}</p>

        {
          data.tags.length > 0 ? (
            <div class="space-y-8">
              {data.tags.map((tagData: any, index: number) => {
                const tagPaths = pathsByTag.get(tagData.name) || [];
                const isActiveTag = tagData.name === tag;
                return (
                  <section
                    data-pagefind-ignore={!isActiveTag ? true : undefined}
                    id={`tag-${tagData.name}`}
                    data-index={index}
                    class="tag-group rounded-lg border border-gray-200 bg-white shadow-sm"
                  >
                    <div class={`border-b px-6 py-4 ${isActiveTag ? "bg-blue-50" : "border-gray-200 bg-gray-50"}`}>
                      <h2 class={`text-2xl font-semibold ${isActiveTag ? "text-primary" : "text-gray-900"}`}>
                        {tagData.name}
                      </h2>
                      {tagData.description && (
                        <div
                          class="markdown-content mt-1 text-sm text-gray-600"
                          set:html={renderMarkdown(tagData.description)}
                        />
                      )}
                    </div>

                    <div class="divide-y divide-gray-100">
                      {tagPaths.map(({ path, method, operation }) => {
                        const key = `${method}-${path}`;
                        const tsSchemas = typescriptSchemas.get(key) || {};
                        const methodColor =
                          {
                            get: "bg-blue-500",
                            post: "bg-green-500",
                            put: "bg-yellow-500",
                            patch: "bg-orange-500",
                            delete: "bg-red-500",
                          }[method] || "bg-gray-500";

                        const parameters = operation.parameters || [];
                        const requestBody = operation.requestBody;
                        const responses = operation.responses || {};

                        return (
                          <details class="path-item group">
                            <summary class="flex cursor-pointer items-center gap-4 px-6 py-4 hover:bg-gray-50">
                              <span
                                class={`inline-block w-20 rounded px-2 py-1 text-center text-xs font-bold text-white uppercase ${methodColor}`}
                              >
                                {method}
                              </span>
                              <span class="font-mono text-sm text-gray-900" set:html={highlightPathParams(path)} />
                              {operation.summary && <span class="text-sm text-gray-600">- {operation.summary}</span>}
                            </summary>

                            <div class="border-t border-gray-100 bg-gray-50 px-6 py-6">
                              {operation.description && (
                                <div class="mb-6">
                                  <h4 class="mb-2 font-semibold text-gray-900">Description</h4>
                                  <div
                                    class="markdown-content text-sm text-gray-600"
                                    set:html={renderMarkdown(operation.description)}
                                  />
                                </div>
                              )}

                              {/* Parameters Section */}
                              {parameters.length > 0 && (
                                <div class="mb-6">
                                  <h4 class="mb-3 font-semibold text-gray-900">Parameters</h4>
                                  <div class="overflow-hidden rounded-lg border border-gray-200">
                                    <table class="min-w-full divide-y divide-gray-200">
                                      <thead class="bg-gray-100">
                                        <tr>
                                          <th class="px-4 py-2 text-left text-xs font-medium text-gray-600 uppercase">
                                            Name
                                          </th>
                                          <th class="px-4 py-2 text-left text-xs font-medium text-gray-600 uppercase">
                                            In
                                          </th>
                                          <th class="px-4 py-2 text-left text-xs font-medium text-gray-600 uppercase">
                                            Type
                                          </th>
                                          <th class="px-4 py-2 text-left text-xs font-medium text-gray-600 uppercase">
                                            Required
                                          </th>
                                          <th class="px-4 py-2 text-left text-xs font-medium text-gray-600 uppercase">
                                            Description
                                          </th>
                                        </tr>
                                      </thead>
                                      <tbody class="divide-y divide-gray-200 bg-white">
                                        {parameters.map((param: any) => (
                                          <tr>
                                            <td class="px-4 py-2 font-mono text-sm text-gray-900">{param.name}</td>
                                            <td class="px-4 py-2 text-sm text-gray-600">{param.in}</td>
                                            <td class="px-4 py-2 font-mono text-sm text-gray-600">
                                              {param.schema?.type || "any"}
                                            </td>
                                            <td class="px-4 py-2 text-sm">
                                              {param.required ? (
                                                <span class="rounded bg-red-100 px-2 py-1 text-xs text-red-700">
                                                  Required
                                                </span>
                                              ) : (
                                                <span class="rounded bg-gray-100 px-2 py-1 text-xs text-gray-600">
                                                  Optional
                                                </span>
                                              )}
                                            </td>
                                            <td class="px-4 py-2 text-sm text-gray-600">
                                              {param.description ? (
                                                <div
                                                  class="markdown-content"
                                                  set:html={renderMarkdown(param.description)}
                                                />
                                              ) : (
                                                "-"
                                              )}
                                            </td>
                                          </tr>
                                        ))}
                                      </tbody>
                                    </table>
                                  </div>
                                </div>
                              )}

                              {/* Request Body Section */}
                              {requestBody && (
                                <div class="mb-6">
                                  <h4 class="mb-3 font-semibold text-gray-900">Request Body</h4>
                                  <div class="rounded-lg border border-gray-200 bg-white">
                                    <div class="flex border-b border-gray-200">
                                      <button
                                        class="schema-tab active px-4 py-2 text-sm font-medium"
                                        data-target={`input-json-${key}`}
                                        onclick={`switchTab(event, 'input-json-${key}')`}
                                      >
                                        Example Value
                                      </button>
                                      {tsSchemas.input && (
                                        <button
                                          class="schema-tab px-4 py-2 text-sm font-medium"
                                          data-target={`input-ts-${key}`}
                                          onclick={`switchTab(event, 'input-ts-${key}')`}
                                        >
                                          TypeScript
                                        </button>
                                      )}
                                    </div>

                                    <div class="p-4">
                                      <div id={`input-json-${key}`} class="schema-content">
                                        <CodeBlock
                                          language="json"
                                          code={JSON.stringify(
                                            schemaToExampleJSON(
                                              requestBody.content?.["application/vnd.api+json"]?.schema ||
                                                requestBody.content?.["application/json"]?.schema ||
                                                requestBody.content?.["multipart/form-data"]?.schema ||
                                                {},
                                            ),
                                            null,
                                            2,
                                          )}
                                        />
                                      </div>

                                      {tsSchemas.input && (
                                        <div id={`input-ts-${key}`} class="schema-content hidden">
                                          <CodeBlock language="typescript" code={tsSchemas.input} />
                                        </div>
                                      )}
                                    </div>
                                  </div>
                                </div>
                              )}

                              {/* Response Section */}
                              {Object.keys(responses).length > 0 && (
                                <div class="mb-6">
                                  <h4 class="mb-3 font-semibold text-gray-900">Response</h4>

                                  {Object.entries(responses).map(([statusCode, response]: [string, any]) => (
                                    <div class="mb-4 rounded-lg border border-gray-200 bg-white">
                                      <div class="flex items-center border-b border-gray-200 bg-gray-50 px-4 py-2">
                                        <span
                                          class={`inline-block rounded px-2 py-1 text-xs font-bold ${
                                            statusCode.startsWith("2")
                                              ? "bg-green-100 text-green-700"
                                              : "bg-red-100 text-red-700"
                                          }`}
                                        >
                                          {statusCode}
                                        </span>
                                        {response.description && (
                                          <div
                                            class="markdown-content ml-2 text-sm text-gray-600"
                                            set:html={renderMarkdown(response.description)}
                                          />
                                        )}
                                      </div>

                                      {response.content && (
                                        <div>
                                          <div class="flex border-b border-gray-200">
                                            <button
                                              class="schema-tab active px-4 py-2 text-sm font-medium"
                                              data-target={`output-json-${key}-${statusCode}`}
                                              onclick={`switchTab(event, 'output-json-${key}-${statusCode}')`}
                                            >
                                              Example Value
                                            </button>
                                            {tsSchemas.output && statusCode === "200" && (
                                              <button
                                                class="schema-tab px-4 py-2 text-sm font-medium"
                                                data-target={`output-ts-${key}`}
                                                onclick={`switchTab(event, 'output-ts-${key}')`}
                                              >
                                                TypeScript
                                              </button>
                                            )}
                                          </div>

                                          <div class="p-4">
                                            <div id={`output-json-${key}-${statusCode}`} class="schema-content">
                                              <CodeBlock
                                                language="json"
                                                code={JSON.stringify(
                                                  schemaToExampleJSON(
                                                    response.content?.["application/vnd.api+json"]?.schema ||
                                                      response.content?.["application/json"]?.schema ||
                                                      response.content?.["multipart/form-data"]?.schema ||
                                                      {},
                                                  ),
                                                  null,
                                                  2,
                                                )}
                                              />
                                            </div>

                                            {tsSchemas.output && statusCode === "200" && (
                                              <div id={`output-ts-${key}`} class="schema-content hidden">
                                                <CodeBlock language="typescript" code={tsSchemas.output} />
                                              </div>
                                            )}
                                          </div>
                                        </div>
                                      )}
                                    </div>
                                  ))}
                                </div>
                              )}
                            </div>
                          </details>
                        );
                      })}
                    </div>
                  </section>
                );
              })}
            </div>
          ) : (
            <div class="rounded-lg border border-gray-200 bg-white p-8 text-center">
              <p class="text-gray-600">No tags found in spec.</p>
            </div>
          )
        }
      </div>
    </PageContainer>

    <Pagination />
  </div>
</PageLayout>

<style>
  .schema-tab {
    border-bottom: 2px solid transparent;
    color: #6b7280;
    transition: all 0.2s;
  }

  .schema-tab:hover {
    color: #374151;
    background-color: #f9fafb;
  }

  .schema-tab.active {
    color: #2563eb;
    border-bottom-color: #2563eb;
    background-color: white;
  }

  details > summary {
    list-style: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::before {
    content: "▶";
    display: inline-block;
    margin-right: 0.5rem;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  details[open] > summary::before {
    transform: rotate(90deg);
  }

  /* Dark mode support - Tailwind class-based */
  :global(.dark) .tag-group,
  :global(.dark) .rounded-lg.border {
    background: #1f2937;
    border-color: #374151;
  }

  :global(.dark) .bg-gray-50 {
    background: #111827 !important;
  }

  :global(.dark) .bg-white {
    background: #1f2937 !important;
  }

  :global(.dark) .bg-gray-100 {
    background: #1f2937 !important;
  }

  :global(.dark) .text-gray-900 {
    color: #f3f4f6 !important;
  }

  :global(.dark) .text-gray-600 {
    color: #9ca3af !important;
  }

  :global(.dark) .border-gray-200,
  :global(.dark) .border-b.border-gray-200,
  :global(.dark) .border-t.border-gray-100 {
    border-color: #374151 !important;
  }

  :global(.dark) .divide-gray-100 > *,
  :global(.dark) .divide-gray-200 > * {
    border-color: #374151 !important;
  }

  /* Fix border radius override by rounding tag header corners */
  .tag-group > div:first-child {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
  }

  /* Fix border radius for Input/Output schema containers */
  .rounded-lg > div:first-child {
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
  }

  /* Ensure tab buttons respect parent's border radius */
  .rounded-lg > .flex.border-b:first-child .schema-tab:first-child {
    border-top-left-radius: 0.5rem;
  }

  :global(.dark) details > summary:hover {
    background-color: #111827 !important;
  }

  :global(.dark) .schema-tab {
    color: #9ca3af;
  }

  :global(.dark) .schema-tab:hover {
    color: #f3f4f6;
    background-color: #111827;
  }

  :global(.dark) .schema-tab.active {
    color: #60a5fa;
    background-color: #1f2937;
  }

  /* Dark mode - Table styling */
  :global(.dark) thead.bg-gray-100 {
    background: #1f2937 !important;
  }

  :global(.dark) tbody.bg-white {
    background: #111827 !important;
  }

  /* Dark mode - Badge colors */
  :global(.dark) .bg-red-100 {
    background: #7f1d1d !important;
  }

  :global(.dark) .text-red-700 {
    color: #fca5a5 !important;
  }

  :global(.dark) .bg-gray-100 {
    background: #374151 !important;
  }

  :global(.dark) .bg-green-100 {
    background: #14532d !important;
  }

  :global(.dark) .text-green-700 {
    color: #86efac !important;
  }

  /* Active tag highlighting - Dark mode */
  :global(.dark) .bg-blue-50 {
    background: #1e3a5f !important;
  }
</style>

<script>
  // TypeScript declaration for page-specific functions
  declare global {
    interface Window {
      switchTab: (event: Event, targetId: string) => void;
    }
  }
</script>

<script is:inline>
  // Tab switching function
  function switchTab(event, targetId) {
    const button = event.currentTarget;
    const container = button.closest(".rounded-lg");

    // Update active tab
    container.querySelectorAll(".schema-tab").forEach((tab) => {
      tab.classList.remove("active");
    });
    button.classList.add("active");

    // Show/hide content
    container.querySelectorAll(".schema-content").forEach((content) => {
      content.classList.add("hidden");
    });
    const targetContent = document.getElementById(targetId);
    if (targetContent) {
      targetContent.classList.remove("hidden");
    }
  }

  // Scroll to tag if specified in URL
  function scrollToTag() {
    // Get tag from data attribute
    const container = document.querySelector("[data-tag]");
    if (!container) return;

    const tag = container.dataset.tag;
    const tagElement = document.getElementById(`tag-${tag}`);

    if (tagElement && tagElement.dataset.index > 0) {
      setTimeout(() => {
        const elementPosition = tagElement.getBoundingClientRect().top + window.pageYOffset;
        const offsetPosition = elementPosition - 80; // 80px offset from top

        window.scrollTo({
          top: offsetPosition,
          behavior: "smooth",
        });
      }, 200);
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      scrollToTag();
    });
  } else {
    scrollToTag();
  }

  // Make functions available globally
  window.switchTab = switchTab;
</script>
